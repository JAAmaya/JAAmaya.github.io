---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { home, profile, routeMap, type Lang, type RouteKey } from "@/data/site";
import { ArrowRight, Binary, Box, CodeXml, Cpu, FileText, Gamepad2, LayoutGrid, Mail, MapPin, PencilLine, Sigma, UserRound } from "@lucide/astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = home[lang];

const cardIcons: Partial<Record<RouteKey, typeof UserRound>> = {
  home: UserRound,
  portfolio: LayoutGrid,
  cv: FileText,
  blog: PencilLine,
};

const cardButtonStyles: Partial<Record<RouteKey, string>> = {
  portfolio:
    "border-sky-300/25 bg-gradient-to-br from-sky-200 via-cyan-100 to-slate-50 text-slate-950 shadow-[0_12px_28px_rgba(56,189,248,0.14)] hover:-translate-y-0.5 hover:brightness-105 hover:shadow-[0_16px_34px_rgba(56,189,248,0.18)]",
  cv:
    "border-amber-200/25 bg-gradient-to-br from-slate-50 via-amber-50 to-orange-100 text-slate-950 shadow-[0_12px_28px_rgba(251,191,36,0.12)] hover:-translate-y-0.5 hover:brightness-105 hover:shadow-[0_16px_34px_rgba(251,191,36,0.16)]",
};

const cardIconStyles: Partial<Record<RouteKey, string>> = {
  portfolio: "text-slate-950",
  cv: "text-slate-950",
  blog: "text-sky-200",
};

const aboutFactIcons: Record<string, typeof UserRound> = {
  Unity: Gamepad2,
  VR: Box,
  Scripting: CodeXml,
  "Gameplay Logic": Cpu,
  "Computer Graphics": Binary,
};

---

<Header lang={lang} active="home" />
<main>
  <section class="relative isolate overflow-hidden bg-[radial-gradient(circle_at_20%_20%,rgba(14,165,233,0.18),transparent_32%),radial-gradient(circle_at_80%_30%,rgba(56,189,248,0.08),transparent_24%),linear-gradient(180deg,rgba(7,11,18,0.98)_0%,rgba(7,11,18,0.94)_100%)]">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_20%_20%,rgba(14,165,233,0.18),transparent_32%),radial-gradient(circle_at_80%_30%,rgba(56,189,248,0.08),transparent_24%),linear-gradient(180deg,rgba(7,11,18,0.98)_0%,rgba(7,11,18,0.94)_100%)]"></div>

    <div class="mx-auto max-w-6xl px-7 pt-16 sm:px-8 lg:px-10 lg:pt-20">
      <div class="max-w-4xl">
        <h1 class="whitespace-nowrap text-[clamp(2.35rem,6vw,4.5rem)] font-black leading-[1.02] text-white">
          {content.title}
        </h1>
        <div class="mt-5">
          <p class="inline-flex whitespace-nowrap rounded-full border border-[var(--color-primary)]/25 bg-sky-300/10 px-4 py-1.5 text-[clamp(0.95rem,2.6vw,1.25rem)] font-medium text-sky-100">
            {content.eyebrow}
          </p>
        </div>
      </div>
    </div>
    <div class="mx-auto max-w-6xl px-5 py-6">
      <article class="theme-panel p-6">
        <div class="mb-4 flex items-center gap-3">
          <span class="grid size-10 place-items-center rounded-md bg-sky-300/12 text-sky-200">
            <UserRound class="size-5" aria-hidden="true" />
          </span>
          <h2 class="text-2xl font-black text-white">{content.about.title}</h2>
        </div>
        <p class="leading-7 text-slate-300">{content.about.body}</p>
        <div class="mt-5 flex flex-wrap gap-2">
          {content.about.facts.map((fact) => (
            <span class="inline-flex items-center gap-1.5 rounded-md border border-[var(--color-border)] bg-white/5 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.08em] text-slate-200">
              {(() => {
                const Icon = aboutFactIcons[fact] ?? Sigma;
                return <Icon class="size-3.5 text-sky-300" aria-hidden="true" />;
              })()}
              {fact}
            </span>
          ))}
        </div>
      </article>
    </div>
    <div class="mx-auto max-w-6xl px-5 py-2">
      <div class="flex flex-wrap gap-3">
      {content.cards.map((card) => {
        const Icon = cardIcons[card.key] ?? ArrowRight;
        const buttonStyle = cardButtonStyles[card.key] ?? "border-[var(--color-border)] bg-white/[0.04] text-white hover:border-sky-300/35 hover:bg-white/[0.08]";
        const iconStyle = cardIconStyles[card.key] ?? "text-sky-200";
        return (
        <a class={`focus-ring inline-flex items-center gap-3 rounded-md border px-5 py-3 text-sm font-black transition ${buttonStyle}`} href={routeMap[card.key][lang]}>
              <span class={`grid shrink-0 place-items-center ${iconStyle}`}>
                <Icon class="size-5" aria-hidden="true" />
              </span>
              <span>{card.title}</span>
              <ArrowRight class={`size-4 shrink-0 ${card.key === "portfolio" || card.key === "cv" ? "text-slate-700" : "text-slate-500"}`} aria-hidden="true" />
        </a>
        );
      })}
      </div>
    </div>
    <div class="mx-auto max-w-6xl px-5 py-6 pb-12">
      <aside class="grid gap-4 sm:grid-cols-2">
        <div class="theme-panel p-6">
          <div class="flex items-start gap-3">
            <span class="grid size-9 shrink-0 place-items-center rounded-md bg-white/8 text-sky-200">
              <Mail class="size-4" aria-hidden="true" />
            </span>
            <div>
              <p class="text-xs font-bold uppercase tracking-[0.16em] text-slate-500">Email</p>
              <a class="focus-ring mt-1 inline-flex rounded text-sm font-semibold text-white hover:text-sky-200" href={`mailto:${profile.email}`}>
                {profile.email}
              </a>
            </div>
          </div>
        </div>
        <div class="theme-panel p-6">
          <div class="flex items-start gap-3">
            <span class="grid size-9 shrink-0 place-items-center rounded-md bg-white/8 text-sky-200">
              <MapPin class="size-4" aria-hidden="true" />
            </span>
            <div>
              <p class="text-xs font-bold uppercase tracking-[0.16em] text-slate-500">Base</p>
              <p class="mt-1 text-sm font-semibold text-white">{profile.location[lang]}</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>
</main>
<Footer lang={lang} />
