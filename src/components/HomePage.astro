---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { home, profile, routeMap, type Lang } from "@/data/site";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = home[lang];
---

<Header lang={lang} active="home" />
<main>
  <section class="mx-auto grid min-h-[calc(100vh-73px)] max-w-6xl items-center gap-10 px-5 py-16 lg:grid-cols-[1.03fr_0.97fr]">
    <div>
      <p class="mb-5 inline-flex rounded-full border border-[var(--color-primary)]/25 bg-sky-300/10 px-3 py-1 text-sm font-medium text-sky-100">
        {content.eyebrow}
      </p>
      <h1 class="max-w-3xl text-5xl font-black leading-[1.02] text-white sm:text-6xl lg:text-7xl">
        {content.title}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
        {content.summary}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="focus-ring rounded-md bg-[var(--color-primary)] px-5 py-3 text-sm font-bold text-slate-950 transition hover:brightness-110" href={routeMap.portfolio[lang]}>
          {content.primaryCta}
        </a>
        <a class="focus-ring rounded-md border border-[var(--color-border)] px-5 py-3 text-sm font-bold text-white transition hover:bg-white/5" href={routeMap.cv[lang]}>
          {content.secondaryCta}
        </a>
      </div>
    </div>

    <div class="theme-panel relative min-h-[440px] overflow-hidden shadow-2xl shadow-sky-950/30">
      <div class="absolute inset-0 bg-[linear-gradient(115deg,rgba(14,165,233,0.22),transparent_42%,rgba(245,158,11,0.2))]"></div>
      <div class="absolute inset-0 opacity-40 [background-image:linear-gradient(rgba(255,255,255,.08)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.08)_1px,transparent_1px)] [background-size:44px_44px]"></div>
      <div class="absolute left-6 right-6 top-8 rounded-md border border-[var(--color-border)] bg-black/35 p-4 backdrop-blur">
        <div class="mb-4 flex gap-2">
          <span class="size-2.5 rounded-full bg-red-300"></span>
          <span class="size-2.5 rounded-full bg-amber-300"></span>
          <span class="size-2.5 rounded-full bg-emerald-300"></span>
        </div>
        <div class="space-y-3 font-mono text-sm text-slate-300">
          <p><span class="text-sky-300">role</span>: Unity Developer;</p>
          <p><span class="text-amber-300">focus</span>: games + VR + systems;</p>
          <p><span class="text-emerald-300">site</span>: personal hub;</p>
        </div>
      </div>
      <div class="absolute bottom-6 left-6 right-6 grid gap-3 sm:grid-cols-3">
        {profile.links.map((link) => (
          <a class="focus-ring rounded-md border border-[var(--color-border)] bg-white/8 px-4 py-3 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/14" href={link.href}>
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="border-y border-[var(--color-border)] bg-white/[0.03]">
    <div class="mx-auto grid max-w-6xl gap-5 px-5 py-16 md:grid-cols-2 xl:grid-cols-4">
      {content.cards.map((card) => (
        <a class="theme-panel focus-ring block p-5 transition hover:-translate-y-1 hover:border-sky-300/35" href={routeMap[card.key][lang]}>
          <h2 class="text-xl font-black text-white">{card.title}</h2>
          <p class="mt-3 leading-7 text-slate-300">{card.description}</p>
        </a>
      ))}
    </div>
  </section>
</main>
<Footer lang={lang} />
