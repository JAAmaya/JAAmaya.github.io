---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { cv, labels, portfolioProjects, profile, type Lang } from "@/data/site";
import { ArrowRight, Briefcase, Code, ExternalLink, FolderOpen, Gamepad2, GitBranch, GraduationCap, Languages, Link, Mail, MapPin } from "@lucide/astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = labels[lang];
const selectedProjects = [
  { project: portfolioProjects.professional[1], href: lang === "en" ? "/portfolio/gran-teatro" : "/es/portfolio/gran-teatro" },
  { project: portfolioProjects.professional[0], href: lang === "en" ? "/portfolio/virion" : "/es/portfolio/virion" },
  { project: portfolioProjects.personal[0], href: lang === "en" ? "/portfolio/mechanoccult" : "/es/portfolio/mechanoccult" },
  { project: portfolioProjects.professional[2], href: lang === "en" ? "/portfolio/sun-burn-nitro" : "/es/portfolio/sun-burn-nitro" },
].filter(Boolean);

const profileIcons = {
  LinkedIn: Link,
  GitHub: GitBranch,
  "Itch.io": Gamepad2,
  Linktree: Link,
};
---

<Header lang={lang} active="cv" />
<main class="mx-auto max-w-6xl px-5 py-16">
  <section class="max-w-3xl">
    <p class="text-sm font-bold uppercase text-[var(--color-secondary)]">CV</p>
    <h1 class="mt-4 text-3xl font-black leading-tight text-white sm:text-4xl">{t.cvTitle}</h1>
  </section>

  <section class="mt-14 grid gap-6 lg:grid-cols-[1fr_0.42fr]">
    <div class="space-y-10">
      <div>
        <h2 class="flex items-center gap-2 text-2xl font-black text-white">
          <Briefcase class="size-5 text-sky-300" aria-hidden="true" />
          {t.experience}
        </h2>
        <div class="mt-5 grid gap-5">
          {cv.experience[lang].map((item) => (
            <article class="theme-panel p-5">
              <p class="text-sm font-bold text-[var(--color-primary)]">{item.period}</p>
              <h3 class="mt-3 text-xl font-black text-white">{item.role}</h3>
              <p class="mt-2 text-sm font-semibold text-slate-400">{item.company}</p>
              <p class="mt-4 leading-7 text-slate-300">{item.description}</p>
              {"links" in item && item.links?.length ? (
                <div class="mt-5 flex flex-wrap gap-3">
                  {item.links.map((link) => (
                    <a class="focus-ring inline-flex items-center gap-2 rounded-md bg-white px-4 py-3 text-sm font-black text-slate-950 transition hover:bg-sky-100" href={link.href}>
                      {link.label}
                      <ArrowRight class="size-4" aria-hidden="true" />
                    </a>
                  ))}
                </div>
              ) : null}
            </article>
          ))}
        </div>
      </div>

      <div>
        <h2 class="flex items-center gap-2 text-2xl font-black text-white">
          <GraduationCap class="size-5 text-amber-300" aria-hidden="true" />
          {t.education}
        </h2>
        <div class="mt-5 grid gap-5">
          {cv.education[lang].map((item) => (
            <article class="theme-panel p-5">
              <p class="text-sm font-bold text-[var(--color-secondary)]">{item.period}</p>
              <h3 class="mt-3 text-xl font-black text-white">{item.title}</h3>
              <p class="mt-2 text-sm font-semibold text-slate-400">{item.institution}</p>
            </article>
          ))}
        </div>
      </div>

      <div>
        <h2 class="flex items-center gap-2 text-2xl font-black text-white">
          <FolderOpen class="size-5 text-sky-300" aria-hidden="true" />
          {t.selectedProjects}
        </h2>
        <div class="mt-5 grid gap-5">
          {selectedProjects.map(({ project, href }) => (
            <a class="theme-panel focus-ring block p-5 transition hover:-translate-y-0.5 hover:border-sky-300/50 hover:bg-white/5" href={href}>
              <p class="text-sm font-bold text-[var(--color-primary)]">
                {project.year} · {project.context[lang]} · {project.engine}
              </p>
              <h3 class="mt-3 flex items-center justify-between gap-3 text-xl font-black text-white">
                {project.title}
                <ArrowRight class="size-4 text-slate-500" aria-hidden="true" />
              </h3>
              <p class="mt-2 text-sm font-semibold text-slate-400">{project.teamOrClient}</p>
              <p class="mt-4 leading-7 text-slate-300">{project.description[lang]}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {project.contributionTags.slice(0, 4).map((tag) => (
                  <span class="rounded bg-sky-300/10 px-2.5 py-1 text-xs font-bold text-sky-100">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <aside class="space-y-6">
      <div class="theme-panel p-5">
        <h2 class="flex items-center gap-2 text-xl font-black text-white">
          <Code class="size-5 text-sky-300" aria-hidden="true" />
          {t.skills}
        </h2>
        <div class="mt-5 flex flex-wrap gap-2">
          {cv.skills.map((skill) => (
            <span class="rounded bg-white/7 px-2.5 py-1 text-xs font-bold text-slate-200">{skill}</span>
          ))}
        </div>
      </div>
      <div class="theme-panel p-5">
        <h2 class="flex items-center gap-2 text-xl font-black text-white">
          <Languages class="size-5 text-sky-300" aria-hidden="true" />
          {t.languages}
        </h2>
        <div class="mt-4 space-y-2 text-slate-300">
          {cv.languages.map((item) => <p>{item[lang]}</p>)}
        </div>
      </div>
      <div class="theme-panel p-5">
        <h2 class="flex items-center gap-2 text-xl font-black text-white">
          <Mail class="size-5 text-sky-300" aria-hidden="true" />
          {labels[lang].contact}
        </h2>
        <p class="mt-3 flex items-center gap-2 text-slate-300">
          <MapPin class="size-4 text-slate-500" aria-hidden="true" />
          {profile.location[lang]}
        </p>
        <a class="focus-ring mt-5 inline-flex items-center gap-2 rounded-md bg-white px-4 py-3 text-sm font-black text-slate-950 transition hover:bg-sky-100" href={`mailto:${profile.email}`}>
          <Mail class="size-4" aria-hidden="true" />
          {profile.email}
        </a>
        <div class="mt-4 flex flex-wrap gap-2">
          {profile.links.map((link) => (
            <a
              class="focus-ring inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] bg-white/7 px-3 py-2 text-sm font-semibold text-white transition hover:bg-white/12"
              href={link.href}
              target="_blank"
              rel="noreferrer"
            >
              {(() => {
                const Icon = profileIcons[link.label as keyof typeof profileIcons] ?? ExternalLink;
                return <Icon class="size-4" aria-hidden="true" />;
              })()}
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </aside>
  </section>
</main>
<Footer lang={lang} />
