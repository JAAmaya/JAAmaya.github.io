---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { cv, labels, portfolioProjects, profile, type Lang } from "@/data/site";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = labels[lang];
const selectedProjects = [
  { project: portfolioProjects.professional[1], href: lang === "en" ? "/portfolio#professional-gran-teatro" : "/es/portfolio#professional-gran-teatro" },
  { project: portfolioProjects.professional[0], href: lang === "en" ? "/portfolio#professional-virion" : "/es/portfolio#professional-virion" },
  { project: portfolioProjects.personal[0], href: lang === "en" ? "/portfolio#personal-mechanoccult" : "/es/portfolio#personal-mechanoccult" },
  { project: portfolioProjects.professional[2], href: lang === "en" ? "/portfolio#professional-sun-burn-nitro" : "/es/portfolio#professional-sun-burn-nitro" },
].filter(Boolean);
---

<Header lang={lang} active="cv" />
<main class="mx-auto max-w-6xl px-5 py-16">
  <section class="max-w-3xl">
    <p class="text-sm font-bold uppercase text-[var(--color-secondary)]">CV</p>
    <h1 class="mt-4 text-5xl font-black leading-tight text-white sm:text-6xl">{t.cvTitle}</h1>
    <p class="mt-6 text-lg leading-8 text-slate-300">{t.cvIntro}</p>
  </section>

  <section class="mt-14 grid gap-6 lg:grid-cols-[1fr_0.42fr]">
    <div class="space-y-10">
      <div>
        <h2 class="text-2xl font-black text-white">{t.experience}</h2>
        <div class="mt-5 grid gap-5">
          {cv.experience[lang].map((item) => (
            <article class="theme-panel p-5">
              <p class="text-sm font-bold text-[var(--color-primary)]">{item.period}</p>
              <h3 class="mt-3 text-xl font-black text-white">{item.role}</h3>
              <p class="mt-2 text-sm font-semibold text-slate-400">{item.company}</p>
              <p class="mt-4 leading-7 text-slate-300">{item.description}</p>
              {"links" in item && item.links?.length ? (
                <div class="mt-5 flex flex-wrap gap-3">
                  {item.links.map((link) => (
                    <a class="focus-ring rounded-md bg-white px-4 py-3 text-sm font-black text-slate-950 transition hover:bg-sky-100" href={link.href}>
                      {link.label}
                    </a>
                  ))}
                </div>
              ) : null}
            </article>
          ))}
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-black text-white">{t.education}</h2>
        <div class="mt-5 grid gap-5">
          {cv.education[lang].map((item) => (
            <article class="theme-panel p-5">
              <p class="text-sm font-bold text-[var(--color-secondary)]">{item.period}</p>
              <h3 class="mt-3 text-xl font-black text-white">{item.title}</h3>
              <p class="mt-2 text-sm font-semibold text-slate-400">{item.institution}</p>
            </article>
          ))}
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-black text-white">{t.selectedProjects}</h2>
        <div class="mt-5 grid gap-5">
          {selectedProjects.map(({ project, href }) => (
            <a class="theme-panel focus-ring block p-5 transition hover:-translate-y-0.5 hover:border-sky-300/50 hover:bg-white/5" href={href}>
              <p class="text-sm font-bold text-[var(--color-primary)]">
                {project.year} · {project.context[lang]} · {project.engine}
              </p>
              <h3 class="mt-3 text-xl font-black text-white">{project.title}</h3>
              <p class="mt-2 text-sm font-semibold text-slate-400">{project.teamOrClient}</p>
              <p class="mt-4 leading-7 text-slate-300">{project.description[lang]}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {project.contributionTags.slice(0, 4).map((tag) => (
                  <span class="rounded bg-sky-300/10 px-2.5 py-1 text-xs font-bold text-sky-100">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <aside class="space-y-6">
      <div class="theme-panel p-5">
        <h2 class="text-xl font-black text-white">{t.skills}</h2>
        <div class="mt-5 flex flex-wrap gap-2">
          {cv.skills.map((skill) => (
            <span class="rounded bg-white/7 px-2.5 py-1 text-xs font-bold text-slate-200">{skill}</span>
          ))}
        </div>
      </div>
      <div class="theme-panel p-5">
        <h2 class="text-xl font-black text-white">{t.languages}</h2>
        <div class="mt-4 space-y-2 text-slate-300">
          {cv.languages.map((item) => <p>{item[lang]}</p>)}
        </div>
      </div>
      <div class="theme-panel p-5">
        <h2 class="text-xl font-black text-white">{labels[lang].contact}</h2>
        <p class="mt-3 text-slate-300">{profile.location[lang]}</p>
        <a class="focus-ring mt-5 inline-flex rounded-md bg-white px-4 py-3 text-sm font-black text-slate-950 transition hover:bg-sky-100" href={`mailto:${profile.email}`}>
          {profile.email}
        </a>
      </div>
    </aside>
  </section>
</main>
<Footer lang={lang} />
