---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { placeholders, type Lang, type RouteKey } from "@/data/site";

interface Props {
  lang: Lang;
  page: "blog" | "games";
  active: RouteKey;
}

const { lang, page, active } = Astro.props;
const content = placeholders[lang][page];
---

<Header lang={lang} active={active} />
<main class="mx-auto max-w-6xl px-5 py-16">
  <section class="grid gap-10 lg:grid-cols-[1fr_0.85fr] lg:items-center">
    <div>
      <p class="text-sm font-bold uppercase text-[var(--color-secondary)]">{content.eyebrow}</p>
      <h1 class="mt-4 max-w-3xl text-5xl font-black leading-tight text-white sm:text-6xl">{content.title}</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300">{content.description}</p>
    </div>
    <div class="theme-panel p-6">
      <div class="space-y-3">
        {content.points.map((point) => (
          <div class="rounded-md border border-[var(--color-border)] bg-white/5 px-4 py-3 text-sm font-bold text-slate-200">
            {point}
          </div>
        ))}
      </div>
    </div>
  </section>
</main>
<Footer lang={lang} />
