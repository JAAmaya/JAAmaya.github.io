---
import { credentials, skills } from "@/data/portfolio";
---

<section id="skills" class="border-y border-white/10 bg-white/[0.03]">
  <div class="mx-auto max-w-6xl px-5 py-20">
    <div class="max-w-2xl">
      <p class="text-sm font-bold uppercase text-amber-300">Skills y credenciales</p>
      <h2 class="mt-3 text-3xl font-black text-white sm:text-4xl">Una base tecnica para construir y publicar.</h2>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {
        credentials.map((item) => (
          <article class="rounded-lg border border-white/10 bg-slate-950/65 p-5">
            <h3 class="text-lg font-bold text-white">{item.label}</h3>
            <p class="mt-3 leading-7 text-slate-300">{item.value}</p>
          </article>
        ))
      }
    </div>

    <div class="mt-10 flex flex-wrap gap-3">
      {
        skills.map((skill) => (
          <span class="rounded-md border border-white/10 bg-white/5 px-3 py-2 text-sm font-semibold text-slate-200">
            {skill}
          </span>
        ))
      }
    </div>
  </div>
</section>
