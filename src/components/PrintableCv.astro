---
import { cv, home, labels, portfolioProjects, profile, type Lang } from "@/data/site";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = labels[lang];
const siteUrl = "https://jaamaya.github.io";
const toAbsoluteHref = (href: string) => (href.startsWith("/") ? `${siteUrl}${href}` : href);
const portfolioUrl = lang === "en" ? `${siteUrl}/portfolio` : `${siteUrl}/es/portfolio`;
const title =
  lang === "en"
    ? "Unity Developer and Game Designer"
    : "Desarrollador Unity y diseñador de videojuegos";
const summary = home[lang].about.body;
const selectedProjects = [
  portfolioProjects.professional[1],
  portfolioProjects.professional[0],
  portfolioProjects.personal[0],
  portfolioProjects.professional[2],
];
---

<main class="cv-sheet">
  <header class="cv-header">
    <div>
      <p class="kicker">{title}</p>
      <h1>{profile.name}</h1>
      <p class="summary">{summary}</p>
    </div>
    <aside class="contact">
      <p>{profile.location[lang]}</p>
      <a href={`mailto:${profile.email}`}>{profile.email}</a>
      <a href={portfolioUrl}>{portfolioUrl.replace("https://", "")}</a>
      <a href={profile.links[0].href}>linkedin.com/in/jordanamaya</a>
      <a href={profile.links[1].href}>github.com/JAAmaya</a>
    </aside>
  </header>

  <section>
    <h2>{t.experience}</h2>
    <div class="stack">
      {cv.experience[lang].map((item) => (
        <article>
          <div class="row">
            <h3>{item.role}</h3>
            <span>{item.period}</span>
          </div>
          <p class="meta">{item.company}</p>
          <p>
            {item.description.map((part) =>
              typeof part === "string" ? (
                part
              ) : (
                <a href={toAbsoluteHref(part.href)}>{part.label}</a>
              ),
            )}
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="two-column">
    <div>
      <h2>{t.education}</h2>
      <div class="stack compact">
        {cv.education[lang].map((item) => (
          <article>
            <div class="row">
              <h3>{item.title}</h3>
              <span>{item.period}</span>
            </div>
            <p class="meta">{item.institution}</p>
          </article>
        ))}
      </div>
    </div>

    <div>
      <h2>{t.skills}</h2>
      <div class="tags">
        {cv.skills.map((skill) => <span>{skill}</span>)}
      </div>
      <h2 class="subhead">{t.languages}</h2>
      <p class="languages">{cv.languages.map((item) => item[lang]).join(" · ")}</p>
    </div>
  </section>

  <section>
    <h2>{t.selectedProjects}</h2>
    <div class="project-grid">
      {selectedProjects.map((project) => (
        <article>
          <div class="row">
            <h3>{project.title}</h3>
            <span>{project.year}</span>
          </div>
          <p class="meta">{project.engine} · {project.teamOrClient}</p>
          <p>{project.roleSummary?.[lang] ?? project.description[lang]}</p>
        </article>
      ))}
    </div>
  </section>
</main>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    background: #f3f6fb;
    color: #111827;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  :global(a) {
    color: #075985;
    text-decoration: none;
  }

  @page {
    size: A4;
    margin: 0;
  }

  .cv-sheet {
    box-sizing: border-box;
    width: 210mm;
    min-height: 297mm;
    padding: 11mm 12mm;
    background: #ffffff;
  }

  .cv-header {
    display: grid;
    grid-template-columns: 1fr 58mm;
    gap: 8mm;
    padding-bottom: 5mm;
    border-bottom: 1px solid #cbd5e1;
  }

  .kicker {
    margin: 0 0 2mm;
    color: #075985;
    font-size: 9pt;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: #0f172a;
    font-size: 27pt;
    line-height: 1;
  }

  .summary {
    margin: 4mm 0 0;
    max-width: 130mm;
    color: #334155;
    font-size: 9.7pt;
    line-height: 1.38;
  }

  .contact {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.4mm;
    color: #334155;
    font-size: 8.5pt;
    line-height: 1.25;
  }

  .contact p {
    margin: 0;
    font-weight: 700;
  }

  section {
    margin-top: 5mm;
  }

  h2 {
    margin: 0 0 2.5mm;
    color: #0f172a;
    font-size: 11pt;
    line-height: 1.1;
    text-transform: uppercase;
    border-bottom: 1px solid #e2e8f0;
    padding-bottom: 1.3mm;
  }

  h3 {
    margin: 0;
    color: #111827;
    font-size: 9.6pt;
    line-height: 1.2;
  }

  p {
    margin: 1.4mm 0 0;
    color: #334155;
    font-size: 8.7pt;
    line-height: 1.34;
  }

  .stack {
    display: grid;
    gap: 3.4mm;
  }

  .compact {
    gap: 2.4mm;
  }

  .row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 5mm;
  }

  .row span {
    flex: 0 0 auto;
    color: #475569;
    font-size: 8.1pt;
    font-weight: 800;
  }

  .meta {
    color: #64748b;
    font-size: 8.2pt;
    font-weight: 700;
  }

  .two-column {
    display: grid;
    grid-template-columns: 1fr 64mm;
    gap: 7mm;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5mm;
  }

  .tags span {
    border: 1px solid #cbd5e1;
    border-radius: 3px;
    padding: 1mm 1.8mm;
    color: #1e293b;
    font-size: 7.6pt;
    font-weight: 800;
    line-height: 1;
  }

  .subhead {
    margin-top: 4mm;
  }

  .languages {
    font-weight: 700;
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5mm 5mm;
  }
</style>
