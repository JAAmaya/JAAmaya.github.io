---
import { profile, type Lang } from "@/data/site";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="mx-auto max-w-6xl px-5 py-8 text-sm text-slate-400">
  <p>&copy; {new Date().getFullYear()} {profile.name}. {lang === "en" ? "Personal website." : "Web personal."}</p>
</footer>
