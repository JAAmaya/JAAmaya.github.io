---
import { projects } from "@/data/portfolio";
---

<section id="proyectos" class="mx-auto max-w-6xl px-5 py-20">
  <div class="flex flex-col justify-between gap-6 sm:flex-row sm:items-end">
    <div class="max-w-2xl">
      <p class="text-sm font-bold uppercase text-sky-300">Proyectos destacados</p>
      <h2 class="mt-3 text-3xl font-black text-white sm:text-4xl">Casos para demostrar criterio, ejecucion e impacto.</h2>
    </div>
    <a class="focus-ring rounded-md border border-white/15 px-4 py-3 text-sm font-bold text-white transition hover:bg-white/5" href="/proyectos">
      Ver todos
    </a>
  </div>

  <div class="mt-10 grid gap-5 lg:grid-cols-3">
    {
      projects.map((project, index) => (
        <article class="group rounded-lg border border-white/10 bg-slate-950/75 p-5 transition hover:-translate-y-1 hover:border-sky-300/35">
          <div class="flex items-center justify-between gap-4">
            <span class="text-sm font-bold text-amber-300">0{index + 1}</span>
            <span class="rounded-full bg-white/8 px-3 py-1 text-xs font-semibold text-slate-300">{project.status}</span>
          </div>
          <h3 class="mt-8 text-2xl font-black text-white">{project.title}</h3>
          <p class="mt-4 min-h-28 leading-7 text-slate-300">{project.description}</p>
          <div class="mt-6 flex flex-wrap gap-2">
            {project.stack.map((item) => (
              <span class="rounded bg-sky-300/10 px-2.5 py-1 text-xs font-bold text-sky-100">{item}</span>
            ))}
          </div>
          <p class="mt-4 text-sm font-semibold text-amber-200">{project.platform}</p>
          <a class="focus-ring mt-6 inline-flex rounded-sm text-sm font-bold text-white underline decoration-sky-300/60 underline-offset-4 transition group-hover:text-sky-200" href={project.href}>
            Abrir proyecto
          </a>
        </article>
      ))
    }
  </div>
</section>
