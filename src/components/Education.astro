---
import { education } from "@/data/portfolio";
---

<section id="educacion" class="mx-auto max-w-6xl px-5 py-20">
  <div class="max-w-2xl">
    <p class="text-sm font-bold uppercase text-sky-300">Educacion</p>
    <h2 class="mt-3 text-3xl font-black text-white sm:text-4xl">Formacion y aprendizaje continuo.</h2>
    <p class="mt-4 leading-7 text-slate-300">
      Un bloque pensado para funcionar como CV: titulaciones, certificaciones y formacion relevante.
    </p>
  </div>

  <div class="mt-10 grid gap-5">
    {
      education.map((item) => (
        <article class="grid gap-5 rounded-lg border border-white/10 bg-slate-950/70 p-5 md:grid-cols-[0.32fr_1fr]">
          <div>
            <p class="text-sm font-bold text-amber-300">{item.period}</p>
            <h3 class="mt-3 text-xl font-black text-white">{item.title}</h3>
            <p class="mt-2 text-sm font-semibold text-slate-400">{item.institution}</p>
          </div>
          <div>
            <p class="leading-7 text-slate-300">{item.description}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {item.highlights.map((highlight) => (
                <span class="rounded bg-white/7 px-2.5 py-1 text-xs font-bold text-slate-200">
                  {highlight}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
