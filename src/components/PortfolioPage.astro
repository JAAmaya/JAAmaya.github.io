---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ProjectCarousel from "@/components/ProjectCarousel.astro";
import { labels, portfolioProjects, type Lang } from "@/data/site";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = labels[lang];
---

<Header lang={lang} active="portfolio" />
<main class="mx-auto max-w-6xl px-5 py-16">
  <section class="max-w-3xl">
    <p class="text-sm font-bold uppercase text-[var(--color-secondary)]">Portfolio</p>
    <h1 class="mt-4 text-5xl font-black leading-tight text-white sm:text-6xl">
      {lang === "en" ? "Selected work in games, VR, and technical prototypes." : "Trabajo seleccionado en videojuegos, VR y prototipos técnicos."}
    </h1>
    <p class="mt-6 text-lg leading-8 text-slate-300">{t.portfolioIntro}</p>
  </section>

  <ProjectCarousel id="professional" title={t.portfolioProfessional} projects={portfolioProjects.professional} lang={lang} />
  <ProjectCarousel id="personal" title={t.portfolioPersonal} projects={portfolioProjects.personal} lang={lang} />
</main>
<Footer lang={lang} />
