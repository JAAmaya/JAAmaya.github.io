---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PortfolioGrid from "@/components/PortfolioGrid.astro";
import { labels, type Lang } from "@/data/site";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = labels[lang];
---

<Header lang={lang} active="portfolio" />
<main class="mx-auto max-w-6xl px-5 py-16">
  <section class="max-w-3xl">
    <h1 class="text-4xl font-black leading-tight text-white sm:text-5xl">Portfolio</h1>
    <p class="mt-6 text-lg leading-8 text-slate-300">{t.portfolioIntro}</p>
  </section>

  <PortfolioGrid lang={lang} />
</main>
<Footer lang={lang} />
