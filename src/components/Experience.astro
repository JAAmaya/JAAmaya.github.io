---
import { experience } from "@/data/portfolio";
---

<section class="border-y border-white/10 bg-white/[0.03]">
  <div class="mx-auto max-w-6xl px-5 py-20">
    <div class="max-w-2xl">
      <p class="text-sm font-bold uppercase text-amber-300">Experiencia</p>
      <h2 class="mt-3 text-3xl font-black text-white sm:text-4xl">Trabajo aplicado en juegos y VR.</h2>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {
        experience.map((item) => (
          <article class="rounded-lg border border-white/10 bg-slate-950/70 p-5">
            <p class="text-sm font-bold text-sky-300">{item.period}</p>
            <h3 class="mt-3 text-xl font-black text-white">{item.role}</h3>
            <p class="mt-2 text-sm font-semibold text-slate-400">{item.company}</p>
            <p class="mt-4 leading-7 text-slate-300">{item.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
