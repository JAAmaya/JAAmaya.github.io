---
import { navigation, profile } from "@/data/portfolio";
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-[#070b12]/85 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4" aria-label="Principal">
    <a class="focus-ring flex items-center gap-3 rounded-sm" href="#inicio" aria-label="Ir al inicio">
      <span class="grid size-9 place-items-center rounded-md bg-white text-sm font-black text-slate-950">JA</span>
      <span class="hidden text-sm font-semibold text-white sm:inline">{profile.name}</span>
    </a>
    <div class="flex items-center gap-1 sm:gap-2">
      {
        navigation.map((item) => (
          <a
            class="focus-ring rounded-sm px-2.5 py-2 text-sm font-medium text-slate-300 transition hover:text-white sm:px-3"
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>
