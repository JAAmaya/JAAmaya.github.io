---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { blog, blogPosts, type Lang } from "@/data/site";
import { Tag } from "@lucide/astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = blog.content[lang];
const posts = blogPosts.filter((post) => post.lang === lang);
---

<Header lang={lang} active="blog" />
<main class="mx-auto max-w-6xl px-5 py-16">
  <section class="max-w-3xl">
    <h1 class="text-4xl font-black leading-tight text-white sm:text-5xl">{content.title}</h1>
    <p class="mt-6 text-lg leading-8 text-slate-300">{content.description}</p>
  </section>

  <section class="mt-10">
    <h2 class="flex items-center gap-2 text-xl font-black text-white">
      <Tag class="size-5 text-sky-300" aria-hidden="true" />
      Tags
    </h2>
    <div class="mt-4 flex flex-wrap gap-2">
      {blog.tags.map((tag) => (
        <span class="rounded-md border border-[var(--color-border)] bg-white/7 px-3 py-1.5 text-sm font-bold text-slate-200">
          {tag}
        </span>
      ))}
    </div>
  </section>

  <section class="mt-12">
    {posts.length ? (
      <div class="grid gap-5 md:grid-cols-2">
        {posts.map((post) => (
          <article class="theme-panel p-5">
            <p class="text-sm font-bold text-[var(--color-primary)]">{post.date}</p>
            <h2 class="mt-3 text-2xl font-black text-white">{post.title}</h2>
            <p class="mt-3 leading-7 text-slate-300">{post.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {post.tags.map((tag) => (
                <span class="rounded bg-sky-300/10 px-2.5 py-1 text-xs font-bold text-sky-100">{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="theme-panel p-6">
        <h2 class="text-2xl font-black text-white">{content.emptyTitle}</h2>
      </div>
    )}
  </section>
</main>
<Footer lang={lang} />
