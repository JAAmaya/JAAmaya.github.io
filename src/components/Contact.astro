---
import { profile } from "@/data/portfolio";
---

<section id="contacto" class="border-t border-white/10 bg-white/[0.03]">
  <div class="mx-auto grid max-w-6xl gap-8 px-5 py-16 md:grid-cols-[1fr_auto] md:items-center">
    <div>
      <p class="text-sm font-bold uppercase text-amber-300">Contacto</p>
      <h2 class="mt-3 text-3xl font-black text-white sm:text-4xl">Hablemos de lo proximo que quieres construir.</h2>
      <p class="mt-4 max-w-2xl leading-7 text-slate-300">
        {profile.location}. Cambia el email y enlaces por tus canales reales antes de publicar.
      </p>
    </div>
    <a class="focus-ring rounded-md bg-white px-6 py-4 text-sm font-black text-slate-950 transition hover:bg-sky-100" href={`mailto:${profile.email}`}>
      {profile.email}
    </a>
  </div>
</section>
