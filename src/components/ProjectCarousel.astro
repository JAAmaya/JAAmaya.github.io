---
import type { Lang, Project } from "@/data/site";

interface Props {
  id: string;
  title: string;
  projects: Project[];
  lang: Lang;
}

const { id, title, projects, lang } = Astro.props;
const toneClass = {
  blue: "from-sky-400/35 via-slate-950 to-blue-950",
  amber: "from-amber-300/35 via-slate-950 to-orange-950",
  green: "from-emerald-300/35 via-slate-950 to-green-950",
  pink: "from-fuchsia-300/35 via-slate-950 to-pink-950",
  violet: "from-violet-300/35 via-slate-950 to-indigo-950",
  red: "from-red-300/35 via-slate-950 to-rose-950",
};
---

<section class="py-16" aria-labelledby={`${id}-title`} data-carousel={id}>
  <div class="mb-6 flex items-end justify-between gap-4">
    <h2 id={`${id}-title`} class="text-3xl font-black text-white sm:text-4xl">{title}</h2>
    <div class="hidden gap-2 sm:flex">
      <button class="focus-ring rounded-md border border-[var(--color-border)] px-3 py-2 text-sm font-black text-white transition hover:bg-white/5" type="button" data-carousel-prev aria-label={lang === "en" ? "Previous project" : "Proyecto anterior"}>←</button>
      <button class="focus-ring rounded-md border border-[var(--color-border)] px-3 py-2 text-sm font-black text-white transition hover:bg-white/5" type="button" data-carousel-next aria-label={lang === "en" ? "Next project" : "Proyecto siguiente"}>→</button>
    </div>
  </div>

  <div class="relative overflow-hidden rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-strong)]">
    {projects.map((project, index) => (
      <article id={`${id}-${project.id}`} class="project-panel scroll-mt-24 gap-0 lg:grid-cols-[1.08fr_0.92fr]" data-panel data-index={index} data-active={index === 0 ? "true" : "false"}>
        <div class={`relative min-h-[330px] overflow-hidden bg-gradient-to-br ${toneClass[project.visualTone]} lg:min-h-[560px]`}>
          {project.images?.length ? (
            <>
              <img
                class="absolute inset-0 size-full object-cover"
                src={project.images[0].src}
                alt={project.images[0].alt[lang]}
                loading={index === 0 ? "eager" : "lazy"}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/35 to-slate-950/15"></div>
              <div class="absolute inset-x-4 bottom-4 flex gap-2 sm:inset-x-8 sm:bottom-8">
                {project.images.slice(1, 5).map((image) => (
                  <img
                    class="h-16 min-w-0 flex-1 rounded-md border border-white/20 object-cover shadow-lg sm:h-24"
                    src={image.src}
                    alt={image.alt[lang]}
                    loading="lazy"
                  />
                ))}
              </div>
            </>
          ) : (
            <div class="absolute inset-0 opacity-35 [background-image:linear-gradient(rgba(255,255,255,.1)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.1)_1px,transparent_1px)] [background-size:36px_36px]"></div>
          )}
          <div class="absolute inset-x-8 top-8 rounded-md border border-white/10 bg-black/35 p-4 backdrop-blur">
            <p class="font-mono text-sm text-slate-300">{project.type[lang]}</p>
          </div>
          <div class={`absolute left-8 right-8 ${project.images?.length ? "bottom-28 sm:bottom-40" : "bottom-8"}`}>
            <p class="text-sm font-black uppercase text-white/70">{project.status[lang]}</p>
            <p class="mt-2 text-5xl font-black text-white">{project.thumbLabel}</p>
          </div>
        </div>

        <div class="p-6 sm:p-8">
          <p class="text-sm font-bold text-[var(--color-secondary)]">{project.status[lang]}</p>
          <h3 class="mt-3 text-3xl font-black text-white">{project.title}</h3>
          <p class="mt-3 text-sm font-semibold text-slate-400">
            {project.year} · {project.teamOrClient} · {project.engine}
          </p>
          <div class="mt-5 flex flex-wrap gap-2">
            {project.contributionTags.map((tag) => (
              <span class="rounded bg-sky-300/10 px-2.5 py-1 text-xs font-bold text-sky-100">{tag}</span>
            ))}
          </div>
          <p class="mt-6 leading-7 text-slate-300">{project.description[lang]}</p>
          <ul class="mt-6 space-y-3 text-slate-300">
            {project.highlights[lang].map((item) => (
              <li class="flex gap-3">
                <span class="mt-2 size-1.5 shrink-0 rounded-full bg-[var(--color-primary)]"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6 flex flex-wrap gap-2">
            {project.stack.map((item) => (
              <span class="rounded bg-white/7 px-2.5 py-1 text-xs font-bold text-slate-200">{item}</span>
            ))}
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            {project.links.map((link) => (
              link.href ? (
                <a class="focus-ring rounded-md bg-white px-4 py-3 text-sm font-black text-slate-950 transition hover:bg-sky-100" href={link.href}>
                  {link.label}
                </a>
              ) : (
                <span class="rounded-md border border-[var(--color-border)] px-4 py-3 text-sm font-black text-slate-500" aria-disabled="true">
                  {link.label}
                </span>
              )
            ))}
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="mt-5 flex items-center justify-center gap-3" role="tablist" aria-label={title}>
    {projects.map((project, index) => (
      <button
        class="project-thumb focus-ring grid size-12 place-items-center rounded-md border border-[var(--color-border)] bg-white text-xs font-black text-slate-950 grayscale transition duration-200 sm:size-14"
        type="button"
        data-thumb
        data-index={index}
        data-active={index === 0 ? "true" : "false"}
        aria-selected={index === 0 ? "true" : "false"}
        aria-label={project.title}
      >
        {project.thumbLabel}
      </button>
    ))}
  </div>

  <div class="mt-4 flex justify-center gap-2 sm:hidden">
    <button class="focus-ring rounded-md border border-[var(--color-border)] px-3 py-2 text-sm font-black text-white transition hover:bg-white/5" type="button" data-carousel-prev aria-label={lang === "en" ? "Previous project" : "Proyecto anterior"}>←</button>
    <button class="focus-ring rounded-md border border-[var(--color-border)] px-3 py-2 text-sm font-black text-white transition hover:bg-white/5" type="button" data-carousel-next aria-label={lang === "en" ? "Next project" : "Proyecto siguiente"}>→</button>
  </div>
</section>

<script>
  const carousels = document.querySelectorAll("[data-carousel]");

  carousels.forEach((carousel) => {
    const panels = Array.from(carousel.querySelectorAll<HTMLElement>("[data-panel]"));
    const thumbs = Array.from(carousel.querySelectorAll<HTMLButtonElement>("[data-thumb]"));
    const prevButtons = carousel.querySelectorAll<HTMLButtonElement>("[data-carousel-prev]");
    const nextButtons = carousel.querySelectorAll<HTMLButtonElement>("[data-carousel-next]");
    let activeIndex = 0;

    const setActive = (index: number) => {
      activeIndex = (index + panels.length) % panels.length;
      panels.forEach((panel, panelIndex) => {
        panel.dataset.active = String(panelIndex === activeIndex);
      });
      thumbs.forEach((thumb, thumbIndex) => {
        const isActive = thumbIndex === activeIndex;
        thumb.dataset.active = String(isActive);
        thumb.setAttribute("aria-selected", String(isActive));
      });
    };

    prevButtons.forEach((button) => button.addEventListener("click", () => setActive(activeIndex - 1)));
    nextButtons.forEach((button) => button.addEventListener("click", () => setActive(activeIndex + 1)));
    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => setActive(Number(thumb.dataset.index || 0)));
      thumb.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          setActive(activeIndex - 1);
          thumbs[activeIndex]?.focus();
        }
        if (event.key === "ArrowRight") {
          event.preventDefault();
          setActive(activeIndex + 1);
          thumbs[activeIndex]?.focus();
        }
      });
    });

    const hash = window.location.hash.slice(1);
    if (hash) {
      const targetPanel = panels.find((panel) => panel.id === hash);
      if (targetPanel?.dataset.index) {
        setActive(Number(targetPanel.dataset.index));
      }
    }
  });
</script>
