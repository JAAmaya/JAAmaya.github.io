---
import ProjectDetailPage from "@/components/ProjectDetailPage.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { detailPortfolioProjects, profile } from "@/data/site";

export function getStaticPaths() {
  return detailPortfolioProjects.map((project) => ({
    params: { slug: project.detailSlug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout title={`${project.title} | ${profile.name}`} description={project.description.es} lang="es">
  <ProjectDetailPage project={project} lang="es" />
</BaseLayout>
