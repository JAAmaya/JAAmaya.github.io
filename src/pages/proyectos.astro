---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { profile, projects } from "@/data/portfolio";
---

<BaseLayout title={`Proyectos | ${profile.name}`} description="Proyectos destacados de videojuegos, VR y experiencias interactivas.">
  <Header />
  <main>
    <section class="mx-auto max-w-6xl px-5 py-16">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase text-amber-300">Proyectos</p>
        <h1 class="mt-4 text-5xl font-black leading-tight text-white sm:text-6xl">
          Juegos, prototipos y experiencias interactivas.
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-300">
          Una pagina hija pensada para crecer como biblioteca de proyectos, con una lectura mas cercana a una galeria de Itch.io: estado, plataforma, tecnologias y enlace directo.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {
          projects.map((project, index) => (
            <article class="overflow-hidden rounded-lg border border-white/10 bg-slate-950/80 transition hover:-translate-y-1 hover:border-sky-300/35">
              <div class="relative aspect-[16/10] border-b border-white/10 bg-slate-900">
                <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(14,165,233,0.28),transparent_45%,rgba(245,158,11,0.24))]"></div>
                <div class="absolute inset-0 opacity-35 [background-image:linear-gradient(rgba(255,255,255,.1)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.1)_1px,transparent_1px)] [background-size:28px_28px]"></div>
                <div class="absolute bottom-4 left-4 right-4 flex items-center justify-between gap-3">
                  <span class="rounded bg-black/45 px-3 py-1 text-xs font-black text-white backdrop-blur">0{index + 1}</span>
                  <span class="rounded bg-sky-300 px-3 py-1 text-xs font-black text-slate-950">{project.status}</span>
                </div>
              </div>
              <div class="p-5">
                <p class="text-sm font-bold text-amber-300">{project.type}</p>
                <h2 class="mt-3 text-2xl font-black text-white">{project.title}</h2>
                <p class="mt-4 min-h-32 leading-7 text-slate-300">{project.description}</p>
                <p class="mt-5 text-sm font-semibold text-sky-200">{project.platform}</p>
                <div class="mt-5 flex flex-wrap gap-2">
                  {project.stack.map((item) => (
                    <span class="rounded bg-white/7 px-2.5 py-1 text-xs font-bold text-slate-200">{item}</span>
                  ))}
                </div>
                <a class="focus-ring mt-7 inline-flex rounded-md bg-white px-4 py-3 text-sm font-black text-slate-950 transition hover:bg-sky-100" href={project.href}>
                  Abrir ficha
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
